<?xml version="1.0" ?>
<robot name="agri_robot">
  <!-- Materials -->
  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>
  <material name="green">
    <color rgba="0.2 0.6 0.2 1"/>
  </material>
  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>

  <!-- CHASSIS LINK (Articulation Root) -->
  <link name="chassis">
    <inertial>
      <mass value="60.0"/>
      <inertia ixx="6.25" ixy="0" ixz="0" iyy="17.45" iyz="0" izz="21.2"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="1.8 1.0 0.5"/>
      </geometry>
      <material name="green"/>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="1.8 1.0 0.5"/>
      </geometry>
    </collision>
  </link>

  <!-- REAR LEFT WHEEL -->
  <joint name="rear_left_wheel_joint" type="continuous">
    <parent link="chassis"/>
    <child link="rear_left_wheel"/>
    <origin rpy="-1.5708 0 0" xyz="-0.6 0.6 -0.35"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="rear_left_wheel">
    <inertial>
      <mass value="4.0"/>
      <inertia ixx="0.245" ixy="0" ixz="0" iyy="0.1358" iyz="0" izz="0.1358"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder length="0.2" radius="0.35"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.2" radius="0.35"/>
      </geometry>
    </collision>
  </link>

  <!-- REAR RIGHT WHEEL -->
  <joint name="rear_right_wheel_joint" type="continuous">
    <parent link="chassis"/>
    <child link="rear_right_wheel"/>
    <origin rpy="1.5708 0 0" xyz="-0.6 -0.6 -0.35"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="rear_right_wheel">
    <inertial>
      <mass value="4.0"/>
      <inertia ixx="0.245" ixy="0" ixz="0" iyy="0.1358" iyz="0" izz="0.1358"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder length="0.2" radius="0.35"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.2" radius="0.35"/>
      </geometry>
    </collision>
  </link>

  <!-- FRONT LEFT WHEEL (Passive) -->
  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="chassis"/>
    <child link="front_left_wheel"/>
    <origin rpy="-1.5708 0 0" xyz="0.6 0.6 -0.35"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="front_left_wheel">
    <visual>
      <geometry>
        <cylinder length="0.2" radius="0.35"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.2" radius="0.35"/>
      </geometry>
    </collision>
  </link>

  <!-- FRONT RIGHT WHEEL (Passive) -->
  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="chassis"/>
    <child link="front_right_wheel"/>
    <origin rpy="1.5708 0 0" xyz="0.6 -0.6 -0.35"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="front_right_wheel">
    <visual>
      <geometry>
        <cylinder length="0.2" radius="0.35"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.2" radius="0.35"/>
      </geometry>
    </collision>
  </link>

</robot>